{
  "dashboard": {
    "id": null,
    "uid": "neo-ai-overview",
    "title": "NEO AI Service Overview",
    "tags": ["neo", "ai", "trading"],
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Total Requests",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "neo_requests_total",
            "legendFormat": "{{endpoint}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "Service Uptime (seconds)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "neo_uptime_seconds",
            "legendFormat": "Uptime"
          }
        ]
      },
      {
        "id": 3,
        "title": "Model Accuracy (R²)",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "neo_model_r2_score",
            "legendFormat": "R²"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.5},
                {"color": "green", "value": 0.8}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Requests Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(neo_requests_total[5m])",
            "legendFormat": "{{endpoint}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Model Training Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "neo_model_trained",
            "legendFormat": "Trained"
          }
        ]
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "version": 1
  },
  "overwrite": true
}
