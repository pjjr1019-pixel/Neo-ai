# ── NEO Hybrid AI — Environment Configuration ─────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── General ────────────────────────────────────────────────────
NEO_ENVIRONMENT=development          # development | staging | production

# ── Authentication / JWT ───────────────────────────────────────
AUTH_SECRET_KEY=                      # REQUIRED in production (≥32 chars)
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

JWT_SECRET_KEY=                       # Falls back to runtime key in dev
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────
DB_DRIVER=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neo_ai
DB_USER=neo
DB_PASSWORD=

# ── API Server ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                    # console | json | plain
LOG_ENABLE_FILE_LOGGING=false
LOG_DIR=logs

# ── Model ──────────────────────────────────────────────────────
MODEL_MODELS_DIR=models
MODEL_DEFAULT_MODEL_TYPE=transformer
MODEL_MAX_TRAINING_EPOCHS=100
MODEL_RANDOM_SEED=42
